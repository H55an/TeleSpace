# --- Telegram Bot Configuration ---
# Your official Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# The ID of the Telegram channel used for file storage
STORAGE_CHANNEL_ID=-100xxxxxxxxxx

# --- Database Configuration ---
# PostgreSQL connection string (e.g., postgresql://user:password@db:5432/dbname)
DATABASE_URL=postgresql://user:password@db:5432/telespace_db

# Individual DB parameters for scripts
DB_HOST=db
DB_USER=telespace_user
DB_PASS=your_secure_password
DB_NAME=telespace_db

# --- AI Integration (Optional) ---
# API Keys for AI features (Gemini, OpenRouter, etc.)
OPENROUTER_API_KEY=your_openrouter_key
GEMINI_API_KEY=your_gemini_key
GOOGLE_API_KEY=your_google_ai_key

# --- Local Telegram Bot API Server ---
# Required if you are running a local Telegram Bot API server for large file support
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
LOCAL_API_URL=http://telegram-bot-api:8081/bot
LOCAL_FILE_URL=http://telegram-bot-api:8081/file/bot

# --- API & Security ---
# Secret key for JWT or session encryption in FastAPI
API_SECRET_KEY=your_super_secret_random_string

# Only used if you have a secondary bot for specific testing/tasks
VICTIM_BOT_TOKEN=your_secondary_bot_token